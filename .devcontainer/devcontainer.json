{
  "name": "UFGenius",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bullseye",
  "remoteUser": "vscode",
  "forwardPorts": [5001],
  "portsAttributes": {
    "5001": {
      "label": "UFGenius Dashboard",
      "onAutoForward": "notify"
    }
  },
  "updateContentCommand": "bash -lc 'python -m pip install --upgrade pip && if [ -f requirements.lock ]; then python -m pip install -r requirements.lock; else python -m pip install -r requirements.txt -c constraints.txt; fi'",
  "postCreateCommand": "bash -lc '[ -f .env ] || cp .env.example .env'",
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/python/current/bin/python",
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": [
          "tests"
        ],
        "terminal.integrated.defaultProfile.linux": "bash"
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  }
}
