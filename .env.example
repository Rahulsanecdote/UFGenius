# ─────────────────────────────────────────────
# UFGenius ALPACA SIGNAL BOT — API KEY TEMPLATE
# Copy this file to .env and fill in your keys
# NEVER commit .env to git
# ─────────────────────────────────────────────

# Market Data
ALPHA_VANTAGE_KEY=
POLYGON_KEY=
FMP_KEY=
FINNHUB_KEY=

# Sentiment
NEWSAPI_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=StockBot/1.0 by u/yourusername

# Macro
FRED_API_KEY=

# Alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
EMAIL_FROM=your_email@gmail.com
EMAIL_PASSWORD=your_16_digit_google_app_password
EMAIL_TO=recipient@email.com

# Alpaca API (Official Stock Trading & Portfolio API)
ALPACA_API_KEY=your_alpaca_key
ALPACA_SECRET_KEY=your_alpaca_secret
ALPACA_PAPER=true

# Network hardening
REQUEST_CONNECT_TIMEOUT_SEC=5
REQUEST_TIMEOUT_SEC=10
REQUEST_MAX_RETRIES=3
REQUEST_BACKOFF_SEC=0.5
REQUEST_POOL_SIZE=20
YFINANCE_TIMEOUT_SEC=15

# Dashboard security
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=5001
DASHBOARD_ALLOW_REMOTE=false
DASHBOARD_API_KEY=
DASHBOARD_API_KEYS=
DASHBOARD_RATE_LIMIT_PER_MIN=60
DASHBOARD_RATE_LIMIT_BACKEND=sqlite
DASHBOARD_RATE_LIMIT_DB_PATH=/tmp/ufgenius_rate_limit.sqlite3
DASHBOARD_TRUST_PROXY=false
DASHBOARD_MIN_ACCOUNT_SIZE=100
DASHBOARD_MAX_ACCOUNT_SIZE=10000000
