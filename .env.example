# ─────────────────────────────────────────────
# ROBINHOOD SIGNAL BOT — API KEY TEMPLATE
# Copy this file to .env and fill in your keys
# NEVER commit .env to git
# ─────────────────────────────────────────────

# Market Data (optional — yfinance is free and requires no key)
ALPHA_VANTAGE_KEY=your_alpha_vantage_key
POLYGON_KEY=your_polygon_key
FMP_KEY=your_financial_modeling_prep_key      # 250 free calls/day
FINNHUB_KEY=your_finnhub_key

# Sentiment
NEWSAPI_KEY=your_newsapi_key                  # 100 free calls/day
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=StockBot/1.0

# Macro
FRED_API_KEY=your_fred_api_key               # Free from fred.stlouisfed.org

# Alerts
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
EMAIL_FROM=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_TO=recipient@email.com

# Robinhood (read-only portfolio tracking — NEVER used for automated trading)
ROBINHOOD_USERNAME=your_robinhood_email
ROBINHOOD_PASSWORD=your_robinhood_password
